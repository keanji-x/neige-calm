{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "npm run lint:js && npm run lint:css",
    "lint:js": "eslint .",
    "lint:css": "stylelint 'src/**/*.css'",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "a11y:e2e": "playwright test --project=a11y e2e/a11y-keyboard.spec.ts",
    "a11y:axe": "playwright test --project=a11y e2e/a11y-axe.spec.ts",
    "a11y": "npm run lint && npm run a11y:e2e && npm run a11y:axe",
    "gen:api": "cargo test --quiet --manifest-path ../Cargo.toml -p calm-server export_bindings_ && cargo test --quiet --manifest-path ../Cargo.toml -p calm-session export_bindings_ && cargo test --quiet --manifest-path ../Cargo.toml -p calm-editor export_bindings_ && cargo run --quiet --manifest-path ../Cargo.toml --bin emit-openapi > src/api/openapi.json && openapi-typescript src/api/openapi.json -o src/api/generated.ts"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.193",
    "@modelcontextprotocol/ext-apps": "^1.7.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@platejs/ai": "^53.0.4",
    "@platejs/autoformat": "^53.0.0",
    "@platejs/basic-nodes": "^53.0.0",
    "@platejs/code-block": "^53.0.0",
    "@platejs/link": "^53.0.3",
    "@platejs/list": "^53.0.2",
    "@platejs/markdown": "^53.0.4",
    "@platejs/selection": "^53.0.0",
    "@tanstack/query-async-storage-persister": "^5.100.11",
    "@tanstack/react-query": "^5.100.11",
    "@tanstack/react-query-persist-client": "^5.100.11",
    "@tanstack/react-router": "^1.170.4",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "ai": "^6.0.191",
    "idb-keyval": "^6.2.2",
    "platejs": "^53.0.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-grid-layout": "^2.2.3",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.59.4",
    "@typescript-eslint/utils": "^8.59.4",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.6",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "openapi-typescript": "^7.13.0",
    "stylelint": "^17.12.0",
    "stylelint-config-recommended": "^18.0.0",
    "typescript": "~5.9.0",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.4",
    "vitest": "^4.1.6"
  }
}

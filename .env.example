# Copy to .env and edit. docker compose auto-loads it.

# Single host port the stack publishes. nginx is the only thing the host
# sees; calm-server is reachable through nginx at /api/.
CALM_PORT=4040

# Where the host-built binary lives. Defaults to the cargo release output.
# CALM_BIN=./target/release/calm-server

# Extra host path to bind-mount at the same path inside the container.
# Useful when the repo (or other state) lives outside $HOME — on this
# machine the repo is /mnt/data2/... with a symlink in $HOME, so we
# mount /mnt/data2 so the symlink resolves inside the container.
# Set to a path you definitely have (e.g. /tmp) to disable, or comment
# the volume out in docker-compose.yml if you don't need it.
CALM_EXTRA_MOUNT=/mnt/data2

# Override sqlite db location (defaults to ~/.local/share/neige-calm/calm.db).
# CALM_DB_URL=sqlite:///home/kenji/.local/share/neige-calm/calm.db?mode=rwc

# Tracing
RUST_LOG=info,calm_server=debug

# ---- Auth (issue #189) ----------------------------------------------------
# Owner credential for calm-server's login flow. The compose file ships a
# known dev default (`owner` / `dev`) so `make dev` works out of the box;
# override here for anything that isn't a throwaway loopback workflow.
# CALM_AUTH_USERNAME=owner
# CALM_AUTH_PASSWORD=changeme

# Bypass LoginPage in local dev — every request is auto-promoted to an
# owner session. Set to `true` ONLY on loopback / single-user dev deploys.
# Leaving this enabled on a network-reachable instance (LAN / VPS /
# tailnet / 0.0.0.0 bind) is equivalent to running with no auth.
# CALM_DEV_AUTOLOGIN=true

# ---- Outbound HTTP proxy --------------------------------------------------
# The server container runs with `network_mode: host`, so `127.0.0.1` from
# inside the container is the host's loopback — a host-side proxy works
# transparently. Override if your proxy lives elsewhere.
# HTTP_PROXY=http://127.0.0.1:10809
# HTTPS_PROXY=http://127.0.0.1:10809
# NO_PROXY=localhost,127.0.0.1,::1

# ---- Codex (OpenAI) plugin overrides ------------------------------------
# Host path to the codex CLI binary. The npm @openai/codex package ships a
# musl static binary at the path below; bind-mounted into the container as
# /usr/local/bin/codex. Override if your install layout differs.
# CALM_CODEX_HOST_BIN=/usr/local/lib/node_modules/@openai/codex/node_modules/@openai/codex-linux-x64/vendor/x86_64-unknown-linux-musl/codex/codex
# Inside the container the binary is invoked as `codex` (PATH lookup).
# CALM_CODEX_BIN=codex
# Host path to the neige-codex-bridge hook binary; defaults to the cargo
# release output.
# CALM_CODEX_BRIDGE_BIN=./target/release/neige-codex-bridge

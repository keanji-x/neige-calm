# Copy to .env and edit. docker compose auto-loads it.

# Single host port the stack publishes. nginx is the only thing the host
# sees; calm-server is reachable through nginx at /api/.
CALM_PORT=4040

# Where the host-built binary lives. Defaults to the cargo release output.
# CALM_BIN=./target/release/calm-server

# Extra host path to bind-mount at the same path inside the container.
# Useful when the repo (or other state) lives outside $HOME — on this
# machine the repo is /mnt/data2/... with a symlink in $HOME, so we
# mount /mnt/data2 so the symlink resolves inside the container.
# Set to a path you definitely have (e.g. /tmp) to disable, or comment
# the volume out in docker-compose.yml if you don't need it.
CALM_EXTRA_MOUNT=/mnt/data2

# Override sqlite db location (defaults to ~/.local/share/neige-calm/calm.db).
# CALM_DB_URL=sqlite:///home/kenji/.local/share/neige-calm/calm.db?mode=rwc

# Tracing
RUST_LOG=info,calm_server=debug

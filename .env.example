# Copy to .env and edit. docker compose auto-loads it.

# Single host port the stack publishes. nginx is the only thing the host
# sees; calm-server is reachable through nginx at /api/.
# 4040 is reserved for host prod. Makefile auto-picks the first free dev
# port starting at PORT_BASE unless CALM_PORT is set explicitly.
# PORT_BASE=4041
# CALM_PORT=4041

# Optional dev instance id. Makefile defaults this to the checkout directory
# name and uses it for the compose project name. Docker dev runtime state
# lives inside the server container on a tmpfs and is removed by
# `docker compose down`.
# DEV_ID=pr315

# Where the host-built binary lives. Defaults to the cargo release output.
# CALM_BIN=./target/release/calm-server

# Extra host path to bind-mount at the same path inside the container.
# Useful when the repo (or other state) lives outside $HOME — on this
# machine the repo is /mnt/data2/... with a symlink in $HOME, so we
# mount /mnt/data2 so the symlink resolves inside the container.
# Set to a path you definitely have (e.g. /tmp) to disable, or comment
# the volume out in docker-compose.yml if you don't need it.
CALM_EXTRA_MOUNT=/mnt/data2

# Override container-local docker dev runtime state locations. These paths are
# inside the server container by default, backed by tmpfs.
# CALM_CONTAINER_STATE_DIR=/var/lib/neige-calm
# CALM_DB_URL=sqlite:///var/lib/neige-calm/calm.db?mode=rwc
# CALM_DATA_DIR=/var/lib/neige-calm/data
# CALM_PLUGINS_DATA_DIR=/var/lib/neige-calm/plugins-data

# Tracing
RUST_LOG=info,calm_server=debug

# ---- Host prod mode (`make prod`) -----------------------------------------
# Runs calm-server directly on the host, without docker. This uses the host
# HOME, ~/.codex, PATH, and login shell; calm-server serves web/dist itself.
# PROD_PORT=4040
# PROD_LISTEN=127.0.0.1:4040
# PROD_DATA_DIR=/home/kenji/.local/share/neige-calm
# PROD_DB_URL=sqlite:///home/kenji/.local/share/neige-calm/calm.db?mode=rwc
# Host prod writes this stable shim path into per-card Codex MCP config.
# `make prod` creates/updates the symlink automatically.
# CALM_MCP_STDIO_SHIM_BIN=/home/kenji/.local/bin/neige-mcp-stdio-shim
# PROD_AUTH_USERNAME=owner
# PROD_AUTH_PASSWORD=dev
# PROD_DEV_AUTOLOGIN=false

# ---- Auth (issue #189) ----------------------------------------------------
# Owner credential for calm-server's login flow. The compose file ships a
# known dev default (`owner` / `dev`) so `make dev` works out of the box;
# override here for anything that isn't a throwaway loopback workflow.
# CALM_AUTH_USERNAME=owner
# CALM_AUTH_PASSWORD=changeme

# Bypass LoginPage in local dev — every request is auto-promoted to an
# owner session. Set to `true` ONLY on loopback / single-user dev deploys.
# Leaving this enabled on a network-reachable instance (LAN / VPS /
# tailnet / 0.0.0.0 bind) is equivalent to running with no auth.
# CALM_DEV_AUTOLOGIN=true

# ---- Outbound HTTP proxy --------------------------------------------------
# The server container runs on the compose bridge network, so a proxy on the
# host loopback is reached via host.docker.internal.
# These names are intentionally not HTTP_PROXY/HTTPS_PROXY: host shell proxy
# values often point at 127.0.0.1, which is wrong inside bridge containers.
# CALM_CONTAINER_HTTP_PROXY=http://host.docker.internal:10809
# CALM_CONTAINER_HTTPS_PROXY=http://host.docker.internal:10809
# CALM_CONTAINER_NO_PROXY=localhost,127.0.0.1,::1

# ---- Codex (OpenAI) plugin overrides ------------------------------------
# Host path to the codex CLI binary. The npm @openai/codex package ships a
# musl static binary at the path below; bind-mounted into the container as
# /usr/local/bin/codex. Override if your install layout differs.
# CALM_CODEX_HOST_BIN=/usr/local/lib/node_modules/@openai/codex/node_modules/@openai/codex-linux-x64/vendor/x86_64-unknown-linux-musl/codex/codex
# Inside the container the binary is invoked as `codex` (PATH lookup).
# CALM_CODEX_BIN=codex
# Host path to the neige-codex-bridge hook binary; defaults to the cargo
# release output.
# CALM_CODEX_BRIDGE_BIN=./target/release/neige-codex-bridge
# Issue #339 PR B — the `neige` CLI binary bind-mounted into the docker
# dev container at /usr/local/bin/neige so spec/worker agents can run
# `neige ls` / `neige cat`. Override if your host build lives elsewhere.
# CALM_NEIGE_CLI_BIN=./target/release/neige
